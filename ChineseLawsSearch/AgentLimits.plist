<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ============================================================
         字数限制 / Word count limits
         -1 = 不限制 / unlimited
         ============================================================ -->

    <!-- coordinator 回答参考长度（提示词里说"复杂案情可超过此值"）-->
    <key>coordinatorAnswerSoftLimitChars</key>
    <integer>800</integer>

    <!-- 公报 ruling_gist 提取上限（数据库层，-1 = 不限）-->
    <key>gazetteRulingGistMaxChars</key>
    <integer>-1</integer>

    <!-- ============================================================
         数量限制 / Count limits
         ============================================================ -->

    <!-- statute 模式：每部法律最多列出的条文数 -->
    <key>statuteArticlesPerLawMax</key>
    <integer>5</integer>

    <!-- statute 模式：所有法律条文总数上限 -->
    <key>statuteArticlesTotalMax</key>
    <integer>10</integer>

    <!-- 路由阶段：选中的细分专家上限 -->
    <key>routingMaxExperts</key>
    <integer>4</integer>

    <!-- 问题拆分：子问题上限 -->
    <key>decompositionMaxSubQuestions</key>
    <integer>4</integer>

    <!-- 专家选择：指导案例候选数（通常 1-3 个） -->
    <key>expertGazetteCandidatesTypical</key>
    <integer>3</integer>

    <!-- 专家选择：指导案例候选上限 -->
    <key>expertGazetteCandidatesMax</key>
    <integer>4</integer>

</dict>
</plist>
